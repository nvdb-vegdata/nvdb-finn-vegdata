{
  "schemaVersion": "v1",
  "type": "Deployment",
  "spec": {
    "name": "nvdb-finn-vegdata",
    "replicas": 1,
    "strategy": "rolling",
    "image": {
      "type": "ImageReferenceDescriptor",
      "spec": {
        "imageRepositoryName": "atlas-docker.artrepo.vegvesen.no/nvdbapil/nvdb-finn-vegdata",
        "port": 8080
      }
    },
    "probes": {
      "readiness": {
        "type": "HttpProbe",
        "spec": {
          "path": "/health/alive",
          "initialDelaySeconds": 5
        }
      },
      "liveness": {
        "type": "HttpProbe",
        "spec": {
          "path": "/health/alive",
          "initialDelaySeconds": 8
        }
      }
    },
    "resources": [
      {
        "type": "MemResources",
        "spec": {
          "min": "200M",
          "max": "200M"
        }
      },
      {
        "type": "CpuResources",
        "spec": {
          "min": "50m"
        }
      }
    ]
  }
}